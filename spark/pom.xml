  <artifactId>spark</artifactId>
  <version>${revision}</version>
  <packaging>pom</packaging>
  <name>Apache HBase - Spark</name>
  <description>Spark Connectors for Apache HBase</description>

  <modules>
    <module>hbase-spark-protocol</module>
    <module>hbase-spark-protocol-shaded</module>
    <module>hbase-spark</module>
    <module>hbase-spark-it</module>
  </modules>

  <properties>
    <protobuf.plugin.version>0.6.1</protobuf.plugin.version>
    <!-- Default Spark 3.x configuration -->
    <jackson.version>2.12.5</jackson.version>
    <spark.version>3.5.5.3.3.6.4-1</spark.version>
    <!-- The following version is in sync with Spark's choice
         Please take caution when this version is modified -->
    <scala.version>2.13.17</scala.version>
    <scala.binary.version>2.13</scala.binary.version>
    <target.jvm>-target:jvm-1.8</target.jvm>
    <!-- ScalaTest version - use 3.2.x for Scala 2.13 compatibility -->
    <scalatest.version>3.2.17</scalatest.version>
    <!-- Servlet API - javax for Spark 3.x, jakarta for Spark 4.x -->
    <servlet.api.groupId>javax.servlet</servlet.api.groupId>
    <servlet.api.artifactId>javax.servlet-api</servlet.api.artifactId>
    <servlet.api.version>3.1.0</servlet.api.version>
    <!-- scala-xml version -->
    <scala.xml.version>1.3.0</scala.xml.version>
    <!-- scala-parallel-collections version -->
    <scala.parallel.version>0.2.0</scala.parallel.version>
    <!--
      Spark 4.x artifacts use Java records (java.lang.Record). The scala-maven-plugin runs Zinc
      in-process when jvmArgs is empty, so scalac uses the SAME JDK as the Maven process.
      You must run Maven with JAVA_HOME pointing at JDK 17+ (setting source/target to 17 is not enough).

      Activate Spark 4 dependency versions with -Pspark-4 OR -Dspark.connector.profile=4.
      Without that, only overriding spark.version leaves compileSource/java.min.version at 1.8.
    -->
  </properties>

