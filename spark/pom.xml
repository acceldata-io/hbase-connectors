  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.xolstice.maven.plugins</groupId>
          <artifactId>protobuf-maven-plugin</artifactId>
          <version>${protobuf.plugin.version}</version>
          <configuration>
            <protocArtifact>com.google.protobuf:protoc:${thirdparty.protobuf.version}:exe:${os.detected.classifier}</protocArtifact>
            <protoSourceRoot>${basedir}/src/main/protobuf/</protoSourceRoot>
            <clearOutputDirectory>false</clearOutputDirectory>
            <checkStaleness>true</checkStaleness>
          </configuration>
        </plugin>
        <plugin>
          <groupId>net.revelc.code</groupId>
          <artifactId>warbucks-maven-plugin</artifactId>
          <version>1.1.0</version>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>

  <profiles>
    <!-- Spark 4.x profile with Scala 2.13 and JDK 17 -->
    <profile>
      <id>spark-4</id>
      <properties>
        <spark.version>4.1.1.3.3.6.4-1</spark.version>
        <scala.version>2.13.17</scala.version>
        <scala.binary.version>2.13</scala.binary.version>
        <jackson.version>2.20.0</jackson.version>
        <target.jvm>-target:17</target.jvm>
        <!-- Java 17 required for Spark 4.x -->
        <compileSource>17</compileSource>
        <!-- Explicit floor so requireJavaVersion matches Spark 4 / java.lang.Record -->
        <java.min.version>17</java.min.version>
        <releaseTarget>17</releaseTarget>
        <!-- ScalaTest 3.2.x required for Scala 2.13 -->
        <scalatest.version>3.2.19</scalatest.version>
        <!-- Jakarta Servlet API for Spark 4.x -->
        <servlet.api.groupId>jakarta.servlet</servlet.api.groupId>
        <servlet.api.artifactId>jakarta.servlet-api</servlet.api.artifactId>
        <servlet.api.version>5.0.0</servlet.api.version>
        <!-- scala-xml 2.x for Scala 2.13 -->
        <scala.xml.version>2.3.0</scala.xml.version>
        <!-- scala-parallel-collections for Scala 2.13 -->
        <scala.parallel.version>1.0.4</scala.parallel.version>
      </properties>
    </profile>

    <!-- Same dependency/toolchain properties as spark-4; for CI/RPM that pass -Dspark.connector.profile=4 -->
    <profile>
      <id>spark-connector-4</id>
      <activation>
        <property>
          <name>spark.connector.profile</name>
          <value>4</value>
        </property>
      </activation>
      <properties>
        <spark.version>4.1.1.3.3.6.4-1</spark.version>
        <scala.version>2.13.17</scala.version>
        <scala.binary.version>2.13</scala.binary.version>
        <jackson.version>2.20.0</jackson.version>
        <target.jvm>-target:17</target.jvm>
        <compileSource>17</compileSource>
        <java.min.version>17</java.min.version>
        <releaseTarget>17</releaseTarget>
        <scalatest.version>3.2.19</scalatest.version>
        <servlet.api.groupId>jakarta.servlet</servlet.api.groupId>
        <servlet.api.artifactId>jakarta.servlet-api</servlet.api.artifactId>
        <servlet.api.version>5.0.0</servlet.api.version>
        <scala.xml.version>2.3.0</scala.xml.version>
        <scala.parallel.version>1.0.4</scala.parallel.version>
      </properties>
    </profile>
